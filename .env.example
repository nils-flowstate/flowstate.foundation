# ── Client (Vite, im Browser sichtbar) ────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# Edge-Function-Basis-URL (.../functions/v1) — primärer Analytics-Schreibpfad
VITE_SUPABASE_FN_URL=https://your-project.supabase.co/functions/v1
# Property-Kennung dieses Repos: foundation | express | how | stoic
VITE_FLOWSTATE_APP=foundation

VITE_CAL_URL=https://cal.com/your-username/connect?layout=month_view
VITE_WA_URL=https://wa.me/message/your-wa-link
VITE_WA_PHONE=49XXXXXXXXXXX

# ── Server-side (NUR für Edge Functions / Supabase Secrets) ────────────
# Niemals mit VITE_ prefixen — diese Werte dürfen NICHT in den Client-Bundle.
# SUPABASE_URL und SUPABASE_SERVICE_ROLE_KEY werden von Supabase automatisch
# in die Function-Runtime injiziert; hier nur zur Dokumentation.
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# HMAC-Salt für IP-Hashing — setzen via: supabase secrets set IP_HASH_SALT=<64hex>
IP_HASH_SALT=set-via-supabase-secrets-64-hex-chars
